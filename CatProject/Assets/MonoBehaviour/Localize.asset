  - _idx: str_desc_building_special_after_1
    _ko: "{0}초마다 수입 +{1} (최대 {2}시간)\n<color=#2DA88A>다음 레벨 +{3}</color>"
    _en: "Income +{1} every {0} second(s) \n({2} hour(s) max)\n<color=#2DA88A>Next level +{3}</color>"
    _ja: "{0}秒ごとに収入+{1}(最大{2}時間)\n<color=#2DA88A>次のレベル+{3}</color>"
    _es: "Ingresos +{1} cada {0} segundo(s) ({2} hora(s) máx.)\n<color=#2DA88A>Siguiente nivel +{3}</color>"
    _tw: "每{0}秒收入 +{1} \n(最多 {2} 小時)\n<color=#2DA88A>下一級 +{3}</color>"
    _ru: "Доход +{1} каждые {0} секунд(ы) \n({2} час(ов) макс)\n<color=#2DA88A>Следующий уровень +{3}</color>"
